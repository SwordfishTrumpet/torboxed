# TorBoxed Environment Configuration
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git (it's in .gitignore)

# --- Debrid Service Selection ---
# Which debrid service to use: "torbox" (default) or "real_debrid"
# DEBRID_SERVICE=torbox

# --- Torbox (DEBRID_SERVICE=torbox) ---
# Torbox API Key - Get from https://torbox.app/settings
TORBOX_API_KEY=your_torbox_api_key_here

# --- Real Debrid (DEBRID_SERVICE=real_debrid) ---
# Real Debrid API Token - Get from https://real-debrid.com/apitoken
# REAL_DEBRID_API_KEY=your_real_debrid_api_key_here

# --- Trakt API Credentials ---
# Get from https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=your_trakt_client_id_here
TRAKT_CLIENT_SECRET=your_trakt_client_secret_here

# Optional: Prowlarr API Key (fallback search source)
# Get from Prowlarr Settings → General
# PROWLARR_API_KEY=your_prowlarr_api_key_here

# Optional: Jackett API Key (alternative fallback search source)
# Get from Jackett Web UI → API Key (top right corner)
# JACKETT_API_KEY=your_jackett_api_key_here

# Optional: Zilean Database URL (for advanced users)
# Default: postgresql://zilean:zilean_password@172.20.0.2:5432/zilean
# ZILEAN_DATABASE_URL=postgresql://user:password@host:5432/zilean
